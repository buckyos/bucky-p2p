#!/bin/sh
# Generated harness pre-commit hook.
#
# Install (choose one):
#   cp harness/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   git config core.hooksPath harness/hooks
#
# Blocks commits when repo-wide harness invariants fail: scaffold completeness
# and module packet schema/approval provenance. Stage- and task-specific checks
# still run inside their owning tasks.

if command -v uv >/dev/null 2>&1; then
    uv run --active python ./harness/scripts/check-all.py
else
    python3 ./harness/scripts/check-all.py 2>/dev/null || python ./harness/scripts/check-all.py
fi

status=$?
if [ "$status" -ne 0 ]; then
    echo "harness pre-commit: check-all failed; commit blocked" >&2
    exit "$status"
fi
